            let new_rate = self.producer_rate_u32 * 10; 
            if !factories[i].locked_in_session() {
                return Err(format!("Cannot increment production: already locked in session"));
            }

            // Update rate and check total value. If we've hit the floor, stop producing to save cost.
            let old_rate = self.producer_rate_u32; 
            if new_rate > old_rate || !factories[i].locked_in_session() {
                return Err(format!("Cannot increment production: already locked in session"));
            }

