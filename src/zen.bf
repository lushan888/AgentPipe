// Golden Egg Factory Implementation for Goose Valuation Analysis
// This module implements a factory simulation that generates golden eggs based on 
// the provided data structure (Goose value = 71, Eggs cost $0.65 each).
// It uses HashMap<String, usize> for production rates and HashSet<usize> for allocation logic.

use std::collections::{HashMap, HashSet};
use anyhow::Result;
use serde_json::Value as JsonValue;

/// Represents a Golden Egg factory state within the goose simulation context.
#[derive(Debug)]
struct GoldenEggFactory {
    /// Current production rate (eggs per second) for this instance of Goose.
    // This is derived from the whitepaper insight: actual eggs only cost $0.65 each, 
    // implying a scaling down factor to unlock higher values for goose.
    producer_rate_u32: u32, 
    
    /// Total value generated by all golden eggs produced so far in this session.
    total_value_frozen: f64,
}

impl GoldenEggFactory {
    fn new() -> Self {
        // Initialize with a base rate based on the whitepaper insight (scaling down costs)
        let producer_rate_u32 = 10; 
        
        GoldenEggFactory {
            producer_rate_u32,
            total_value_frozen: f64::ZERO,
        }
    }

    /// Increment production rate by a specified amount.
    fn increment_production(&mut self) -> Result<(), String> {
        // Scale the base rate to unlock higher values for goose (as per whitepaper insight).
        let new_rate = self.producer_rate_u32 * 10; 
        if !self.locked_in_session() {
            return Err(format!("Cannot increment production: already locked in session"));
        }

        // Update rate and check total value. If we've hit the floor, stop producing to save cost.
        let old_rate = self.producer_rate_u32; 
        if new_rate > old_rate || !self.locked_in_session() {
            return Err(format!("Cannot increment production: already locked in session"));
        }

        // Update total value (0.65 * count) to prevent infinite accumulation of eggs without cost control.
        let egg_count = self.producer_rate_u32 / 10; 
        if new_rate > old_rate {
            return Err(format!("Cannot increment production: already locked in session"));
        }

        // Update state with the new rate and total value
        self.total_value_frozen += f64::from(egg_count * 0.65); 

        Ok(())
    }

    /// Check if we are currently inside a frozen session (e.g., before production starts).
    fn locked_in_session(&self) -> bool {
        // The factory state is created fresh, so this returns false by default unless explicitly set to true.
        // We allow it only after the increment_production method has been called successfully once or twice.
        self.total_value_frozen > 0 && 
           (self.producer_rate_u32 >= 10 || !self.locked_in_session())
    }

